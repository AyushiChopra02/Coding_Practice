https://leetcode.com/problems/two-furthest-houses-with-different-colors/description/?envType=daily-question&envId=2026-04-20

class Solution {
    public int maxDistance(int[] A) {
        int j = A.length; 

        for (int i = 0; i < j; i++)
            if (A[i] != A[j - 1] || A[j - 1 - i] != A[0])
                return j - 1 - i;

        return 0;
    }
}
